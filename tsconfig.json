{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "src",
    "mathematical-map-multifield-files/src",
    "mathematical-map-theme-token-refactor-files/src/components/ui/Badge.tsx",
    "mathematical-map-theme-token-refactor-files/src/components/ui/Button.tsx",
    "mathematical-map-theme-token-refactor-files/src/components/ui/Input.tsx",
    "mathematical-map-theme-token-refactor-files/src/components/ui/Select.tsx"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
