{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Topology Knowledge Graph Dataset Schema",
  "description": "JSON schema for topology content nodes with first-class directed dependency edges",
  "type": "object",
  "required": ["schemaVersion", "metadata", "nodes", "edges"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Version of the schema",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "description": "Dataset metadata and documentation",
      "required": ["title", "description", "source", "nodeCount", "edgeCount"],
      "properties": {
        "title": {
          "type": "string",
          "description": "Human-readable title of the dataset"
        },
        "description": {
          "type": "string",
          "description": "Dataset description and derivation information"
        },
        "source": {
          "type": "string",
          "description": "Source file or reference"
        },
        "nodeCount": {
          "type": "integer",
          "description": "Total number of nodes in the dataset",
          "minimum": 0
        },
        "edgeCount": {
          "type": "integer",
          "description": "Total number of edges in the dataset",
          "minimum": 0
        },
        "kindCounts": {
          "type": "object",
          "description": "Count of nodes by kind",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "edgeTypeCounts": {
          "type": "object",
          "description": "Count of edges by type",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "fields": {
          "type": "object",
          "description": "Documentation of all available fields",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "nodes": {
      "type": "array",
      "description": "Array of topology content nodes",
      "items": {
        "type": "object",
        "description": "A single topology content node",
        "properties": {
          "id": {
            "type": "string",
            "description": "Stable slug identifier for the node"
          },
          "kind": {
            "type": "string",
            "enum": [
              "definition",
              "theorem",
              "lemma",
              "corollary",
              "example",
              "exercise",
              "remark",
              "proposition"
            ],
            "description": "Mathematical content type"
          },
          "number": {
            "type": "string",
            "description": "Displayed item number from the source text"
          },
          "title": {
            "type": "string",
            "description": "Human-readable title"
          },
          "chapter": {
            "type": "string",
            "description": "Source chapter label (numeric or single-letter appendix)"
          },
          "section": {
            "type": "string",
            "description": "Source section label (numeric or single-letter appendix)"
          },
          "sectionTitle": {
            "type": "string",
            "description": "Source section title"
          },
          "topicCluster": {
            "type": "string",
            "description": "Coarse topical grouping"
          },
          "originalText": {
            "type": "string",
            "description": "Cleaned source text with Unicode math converted to MathJax/LaTeX"
          },
          "formalStatement": {
            "type": "string",
            "description": "Optional concise formal statement"
          },
          "explanation": {
            "type": "string",
            "description": "Optional explanatory text"
          },
          "statementDependencies": {
            "type": "array",
            "description": "IDs of nodes needed to understand the statement",
            "items": {
              "type": "string"
            }
          },
          "proofDependencies": {
            "type": "array",
            "description": "IDs of nodes used in the proof or justification",
            "items": {
              "type": "string"
            }
          },
          "tags": {
            "type": "array",
            "description": "Normalized lowercase topical tags",
            "items": {
              "type": "string"
            }
          }
        },
        "required": ["id", "kind", "title"],
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "description": "Array of first-class directed dependency edges",
      "items": {
        "type": "object",
        "description": "A directed dependency edge between two nodes",
        "properties": {
          "source": {
            "type": "string",
            "description": "ID of the prerequisite/source node"
          },
          "target": {
            "type": "string",
            "description": "ID of the dependent/target node"
          },
          "edgeType": {
            "type": "string",
            "enum": ["statementDependency", "proofDependency"],
            "description": "Type of dependency relationship"
          },
          "confidence": {
            "type": "number",
            "description": "Confidence level of the edge",
            "minimum": 0,
            "maximum": 1
          },
          "label": {
            "type": "string",
            "description": "Human-readable edge relation description"
          },
          "id": {
            "type": "string",
            "description": "Optional edge identifier"
          }
        },
        "required": ["source", "target", "edgeType"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
